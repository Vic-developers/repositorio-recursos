APP_NAME="Repositorio Recursos Educativos"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=${APP_URL}

DB_CONNECTION=mysql
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_DATABASE=${DB_DATABASE}
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}

CACHE_STORE=file
SESSION_DRIVER=cookie

FILESYSTEM_DISK=public
